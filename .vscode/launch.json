// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
  "version": "0.2.0",
  "configurations": [
      
    {
      "name": "VSCode - Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--disable-extensions", "--extensionDevelopmentPath=${workspaceFolder}/packages/kilo-vscode"],
      "outFiles": ["${workspaceFolder}/packages/kilo-vscode/dist/**/*.js"],
      "preLaunchTask": "VSCode - Compile"
    },
    {
      "name": "VSCode - Run Extension (Local Backend)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--disable-extensions", "--extensionDevelopmentPath=${workspaceFolder}/packages/kilo-vscode"],
      "outFiles": ["${workspaceFolder}/packages/kilo-vscode/dist/**/*.js"],
      "preLaunchTask": "VSCode - Compile",
      "env": {
        "KILO_API_URL": "http://localhost:3000"
      }
    },
    {
      "name": "Bun - Launch lesson00 inspect --bad",
      "type": "bun",
      "request": "launch",
      "program": "${workspaceFolder}/packages/opencode/kilocode-practice/lesson00-cli-entry/index.ts",
      "args": ["inspect", "--bad"],
      "cwd": "${workspaceFolder}",
      "runtime": "bun",
      "stopOnEntry": true
    },
    {
      "name": "Bun - Launch lesson00 inspect",
      "type": "bun",
      "request": "launch",
      "program": "${workspaceFolder}/packages/opencode/kilocode-practice/lesson00-cli-entry/index.ts",
      "args": ["inspect"],
      "cwd": "${workspaceFolder}",
      "runtime": "bun",
      "stopOnEntry": true
    },
    {
      "name": "Bun - Launch lesson00 hello",
      "type": "bun",
      "request": "launch",
      "program": "${workspaceFolder}/packages/opencode/kilocode-practice/lesson00-cli-entry/index.ts",
      "args": ["hello", "--name", "qiuyu", "--print-logs"],
      "cwd": "${workspaceFolder}",
      "runtime": "bun",
      "stopOnEntry": true
    },
    {
      "name": "Bun - Launch lesson00 explode",
      "type": "bun",
      "request": "launch",
      "program": "${workspaceFolder}/packages/opencode/kilocode-practice/lesson00-cli-entry/index.ts",
      "args": ["explode"],
      "cwd": "${workspaceFolder}",
      "runtime": "bun",
      "stopOnEntry": true
    },
    {
      "name": "Bun - Attach",
      "type": "bun",
      "request": "attach",
      "url": "ws://localhost:6499/lesson00"
    }
  ]
}
