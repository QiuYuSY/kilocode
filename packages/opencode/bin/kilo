#!/bin/sh
# kilocode_change - new file
# Shell wrapper that checks for Node.js before launching the JS entry point.
# When installed via npm, the shebang "#!/usr/bin/env node" in the JS file
# produces a cryptic "node: not found" error if Node.js is not in PATH
# (common on WSL where Node may only be installed on the Windows side).
# This wrapper provides an actionable error message instead.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Resolve symlinks to find the real script directory
if [ -L "$0" ]; then
  RESOLVED="$(readlink -f "$0" 2>/dev/null || readlink "$0")"
  SCRIPT_DIR="$(cd "$(dirname "$RESOLVED")" && pwd)"
fi

if ! command -v node >/dev/null 2>&1; then
  echo "Error: Node.js is not found." >&2
  echo "" >&2
  echo "The Kilo CLI requires Node.js to bootstrap. Please ensure Node.js is" >&2
  echo "installed and available in your PATH." >&2
  echo "" >&2
  echo "Common fixes:" >&2
  echo "  - Install Node.js: https://nodejs.org" >&2
  echo "  - On WSL, install Node.js inside your Linux distribution separately" >&2
  echo "    from any Windows installation (e.g. via nvm, fnm, or apt)." >&2
  echo "  - Verify with: node --version" >&2
  exit 1
fi

exec node "$SCRIPT_DIR/kilo.cjs" "$@"
